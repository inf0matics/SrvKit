# SrvKit configuration — all config via env vars only, no secrets in the repo.

# Port the server listens on (Nuxt/Nitro default is 3000).
PORT=3000

# SQLite database path. In the container this defaults to /data/srvkit.db on the
# persisted volume; locally it falls back to ./.data/srvkit.db.
DATABASE_PATH=./.data/srvkit.db

# Session lifetime in seconds of inactivity (default 86400 = 24h).
SESSION_TTL=86400

# Set to "false" to allow non-Secure session cookies over plain http (local dev
# / e2e only). In production (behind Traefik TLS) leave this unset.
# COOKIE_SECURE=false

# Tip Jar link shown in the app sidebar. Hidden entirely when unset.
# TIP_JAR_URL=https://thespielplatz.com/tip-jar

# Secret used to encrypt stored credentials (backup-target passwords) at rest.
# REQUIRED for the Backups feature. Must stay stable — changing it makes
# existing encrypted secrets undecryptable. Use a long random value.
ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Base directory holding mounted backup sources (each sub-directory is a source,
# e.g. mount /root -> /backups/root:ro). Defaults to /backups in the container.
BACKUP_SOURCES_DIR=/backups

# Alerting (Telegram) — optional. The bot token + chat ID are normally set via
# Settings → Alerts (token stored encrypted). These env vars seed the defaults
# for a fresh deploy; the UI overrides them.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# PostgreSQL backup jobs run pg_dump via the Docker socket. Mount it into the
# container to enable them:  - /var/run/docker.sock:/var/run/docker.sock
# Override the path only if your socket lives elsewhere.
# DOCKER_SOCKET=/var/run/docker.sock

# Host monitoring reads the host's /proc and /sys, mounted read-only into the
# container (docker-compose.yml):
#   - /proc:/host/proc:ro
#   - /sys:/host/sys:ro
#   - /:/host/root:ro              # disk usage / inode metrics
#   - /etc/mtab:/host/etc/mtab:ro  # optional (falls back to /host/proc/mounts)
# Override the in-container paths only if you mount them elsewhere.
# HOST_PROC=/host/proc
# HOST_SYS=/host/sys
# HOST_ROOT=/host/root
# HOST_MTAB=/host/etc/mtab
