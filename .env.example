# SrvKit configuration — all config via env vars only, no secrets in the repo.

# Port the server listens on (Nuxt/Nitro default is 3000).
PORT=3000

# SQLite database path. In the container this defaults to /data/srvkit.db on the
# persisted volume; locally it falls back to ./.data/srvkit.db.
DATABASE_PATH=./.data/srvkit.db

# Session lifetime in seconds of inactivity (default 86400 = 24h).
SESSION_TTL=86400

# Set to "false" to allow non-Secure session cookies over plain http (local dev
# / e2e only). In production (behind Traefik TLS) leave this unset.
# COOKIE_SECURE=false

# Tip Jar link shown in the app sidebar. Hidden entirely when unset.
# TIP_JAR_URL=https://thespielplatz.com/tip-jar
